# Copy to .env and fill in. Never commit the real .env.

# --- Gateway ---
PORT=8080
LOG_LEVEL=info
# Protects /admin/* (the control plane). Control-plane WRITES are refused while
# this is the default `change-me` — set a strong value: `make gen-token`
# (or `openssl rand -hex 32`).
ADMIN_TOKEN=change-me

# --- Providers (real keys, server-side only — never logged or returned) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_VERSION=2023-06-01
# ANTHROPIC_MAX_TOKENS=4096   # backfilled when a request omits max_tokens

# --- Routing & failover ---
# Requests route to a provider by model (pricing.yaml's `provider`, then a
# name-prefix heuristic, then DEFAULT_PROVIDER). On a primary 5xx/timeout the
# gateway fails over to FAILOVER_PROVIDER using FAILOVER_MODEL.
DEFAULT_PROVIDER=openai
FAILOVER_ENABLED=true
FAILOVER_PROVIDER=
FAILOVER_MODEL=

# --- Upstream resilience (retry + circuit breaker) ---
# Each upstream call is retried on transient failures (transport error, 5xx, or
# 429) with exponential backoff + jitter. Independently, a per-provider circuit
# breaker trips after BREAKER_THRESHOLD consecutive failures and fails fast (the
# gateway then fails over, if configured) until a half-open probe succeeds.
RETRY_MAX_ATTEMPTS=3          # total attempts per provider (1 = no retry)
RETRY_BASE_DELAY_MS=200       # backoff before the first retry
RETRY_MAX_DELAY_MS=2000       # backoff cap
BREAKER_ENABLED=true
BREAKER_THRESHOLD=5           # consecutive failures that open a breaker
BREAKER_COOLDOWN_SECONDS=30   # how long it stays open before a trial
BREAKER_HALFOPEN_MAX=1        # trial requests allowed while half-open

# --- Infra ---
# For local (non-Docker) runs use localhost; inside compose the gateway uses
# the service hostnames (redis / postgres) set in docker-compose.yml.
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgres://gw:gw@localhost:5432/aigateway?sslmode=disable

# Host ports published by compose. Override if 6379/5432 are already in use
# on your machine (e.g. another local Redis/Postgres). Defaults shown.
REDIS_HOST_PORT=6379
POSTGRES_HOST_PORT=5432

# --- Cache ---
CACHE_TTL_SECONDS=3600
# CACHE_SCOPE=key            # key (per-virtual-key, isolated) | global (shared)

# --- Semantic cache (Phase 6, opt-in) ---
# Embeds each request and serves near-duplicate prompts from a pgvector store.
# Adds an embeddings call per non-exact-cache request and can return a similar
# prompt's answer — keep the threshold conservative.
SEMANTIC_CACHE_ENABLED=false
SEMANTIC_THRESHOLD=0.25       # max cosine distance for a hit (smaller = stricter)
EMBEDDING_MODEL=text-embedding-3-small

# --- Budgets ---
# Enforce per-key monthly spend caps. A key is only checked when its
# monthly_budget_usd is set (via the dashboard or POST /admin/keys); once spend
# meets the cap, requests are blocked with HTTP 402. Set false to track spend
# without blocking.
BUDGET_ENFORCED=true

# --- Pricing ---
PRICING_PATH=pricing.yaml
